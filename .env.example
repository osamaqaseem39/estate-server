# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb://127.0.0.1:27017/gt_estate

# JWT for /api/auth and protected admin routes (use a long random string in production)
JWT_SECRET=change-me-in-production

# Server port (default 3000)
PORT=3000

# Optional: set to production to hide Swagger UI
# NODE_ENV=production

# Allowed CORS origins: browser URLs of your website + dashboard (comma-separated, no spaces after commas).
# Local dev (localhost / 127.0.0.1) and https://*.vercel.app are allowed by default unless CORS_STRICT=true.
# CORS_ORIGINS=https://www.example.com,https://dashboard.example.com
# CORS_STRICT=true
