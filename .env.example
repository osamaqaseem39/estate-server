# Optional: override local upload directory (defaults to ../uploads, or /tmp on Vercel)
# UPLOADS_DIR=/var/data/uploads

# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb://127.0.0.1:27017/gt_estate

# JWT for /api/auth and protected admin routes (use a long random string in production)
JWT_SECRET=change-me-in-production

# Server port (default 3000)
PORT=3000

# Max upload size in bytes (multer). Images: properties + gallery. CV: careers applications.
# MAX_IMAGE_UPLOAD_BYTES=5242880
# MAX_CV_UPLOAD_BYTES=8388608

# Optional: set to production to hide Swagger UI
# NODE_ENV=production

# Allowed CORS origins: browser URLs of your website + dashboard (comma-separated, no spaces after commas).
# Local dev (localhost / 127.0.0.1), https://*.vercel.app, and https://gtestates.com.pk / https://www.gtestates.com.pk
# are allowed by default unless you rely only on CORS_ORIGINS with CORS_STRICT=true (Vercel wildcard is off when strict).
# Add your marketing site URL if it uses a custom domain not covered above, e.g.:
# CORS_ORIGINS=https://gtestates.com.pk,https://www.gtestates.com.pk,https://your-site.vercel.app,http://localhost:3001
# CORS_STRICT=true

# SMTP — inquiry form notifications (optional; inquiries are still saved to MongoDB)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="GT Estate <noreply@yourdomain.com>"
# INQUIRY_NOTIFY_EMAIL=team@yourdomain.com
