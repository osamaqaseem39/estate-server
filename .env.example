# MongoDB connection string (Atlas or local)
MONGODB_URI=mongodb://127.0.0.1:27017/gt_estate

# JWT for /api/auth and protected admin routes (use a long random string in production)
JWT_SECRET=change-me-in-production

# Server port (default 3000)
PORT=3000

# Optional: set to production to hide Swagger UI
# NODE_ENV=production

# Optional: extra allowed CORS origins (comma-separated, no spaces). Default list includes the dashboard + API host on Vercel.
# CORS_ORIGINS=https://your-marketing-site.vercel.app,https://www.example.com
